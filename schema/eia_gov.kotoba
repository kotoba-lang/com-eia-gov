// Eia_gov clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace eia_gov {

    entity Meter {
        id: string @unique
        serial: string
        type: string
        location: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Reading {
        id: string @unique
        meterId: string
        value: float
        unit: string
        readAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Node {
        id: string @unique
        name: string
        region: string
        voltageKv: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity LoadForecast {
        id: string @unique
        nodeId: string
        period: string
        megawatts: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity MarketBid {
        id: string @unique
        nodeId: string
        price: float
        megawatts: float
        interval: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Tag {
        id: string @unique
        nodeId: string
        address: string
        value: float
        quality: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
